    "express": "^5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.3",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "vitest": "^4.1.0"
  }
